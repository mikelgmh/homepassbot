# ── Telegram ──────────────────────────────────────────────
# Required: get this from @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklmNOPqrSTUvwxYZ

# ── Home Assistant ────────────────────────────────────────
# Required: your Home Assistant instance URL
HA_URL=https://home.example.com
# Required: generate in HA → Profile → Long-Lived Access Tokens
HA_TOKEN=eyJhbGciOiJIUzI1NiIs...

# ── Admin ─────────────────────────────────────────────────
# Required: your Telegram numeric ID (message @userinfobot to get it)
ADMIN_ID=123456789

# ── Database ──────────────────────────────────────────────
# Optional: sqlite (default) or postgres
DATABASE_PROVIDER=sqlite
# Optional: connection string (default: bot.sqlite)
DATABASE_URL=bot.sqlite
# Required only if DATABASE_PROVIDER=postgres:
DB_PASSWORD=changeme

# ── Mode ──────────────────────────────────────────────────
# Optional: polling (default) or webhook
BOT_MODE=polling
# Only needed if BOT_MODE=webhook:
WEBHOOK_URL=https://yourdomain.com
PORT=3000
